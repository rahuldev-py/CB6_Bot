# .env.example — CB6 Quantum credential template
#
# SECURITY RULES
# ──────────────
# 1. Copy this file to .env  →  never commit .env to source control
# 2. Never paste real values into this file
# 3. Add .env and .env.local to .gitignore (already done)
# 4. On VPS / production: set vars via shell export or systemd EnvironmentFile
#
# Usage:
#   cp .env.example .env
#   # then edit .env with your actual credentials

# ══════════════════════════════════════════════════════════════════════════════
# NSE / FYERS
# ══════════════════════════════════════════════════════════════════════════════

FYERS_CLIENT_ID=
FYERS_SECRET_KEY=
FYERS_REDIRECT_URI=
FYERS_ACCESS_TOKEN=          # populated by auto_token.py — do not hardcode

# ══════════════════════════════════════════════════════════════════════════════
# NSE TELEGRAM BOT
# ══════════════════════════════════════════════════════════════════════════════

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ══════════════════════════════════════════════════════════════════════════════
# FOREX — MT5 FTMO ACCOUNT
# ══════════════════════════════════════════════════════════════════════════════

MT5_FTMO_LOGIN=
MT5_FTMO_PASSWORD=
MT5_FTMO_SERVER=
MT5_FTMO_TERMINAL_PATH=      # e.g. C:\Program Files\FTMO MetaTrader 5\terminal64.exe

# ══════════════════════════════════════════════════════════════════════════════
# FOREX — MT5 GFT ACCOUNT
# ══════════════════════════════════════════════════════════════════════════════

MT5_GFT_LOGIN=
MT5_GFT_PASSWORD=
MT5_GFT_SERVER=
MT5_GFT_TERMINAL_PATH=       # e.g. C:\Program Files\GFT MetaTrader 5\terminal64.exe

# ══════════════════════════════════════════════════════════════════════════════
# FOREX TELEGRAM BOTS
# ══════════════════════════════════════════════════════════════════════════════

FOREX_TELEGRAM_TOKEN=        # FTMO Telegram bot token
GFT_TELEGRAM_TOKEN=          # GFT Telegram bot token (separate bot)
CB6_ADMIN_USER_ID=           # Your Telegram numeric user ID

# ══════════════════════════════════════════════════════════════════════════════
# ENGINE FLAGS (optional — safe defaults shown)
# ══════════════════════════════════════════════════════════════════════════════

FOREX_PAPER=true             # true = paper trading; false = live orders
BLOCK_NEWS=false             # true = honour manual NEWS_WINDOWS list

# ══════════════════════════════════════════════════════════════════════════════
# TRUEDATA (NSE real-time feed)
# ══════════════════════════════════════════════════════════════════════════════

TRUEDATA_USERNAME=
TRUEDATA_PASSWORD=

# NSE / IIFL CAPITAL MARKETS API (optional, disabled unless used by tooling)
IIFL_SOURCE=WebAPI
IIFL_MARKETDATA_BASE_URL=https://ttblaze.iifl.com/apibinarymarketdata
IIFL_INTERACTIVE_BASE_URL=https://ttblaze.iifl.com/interactive
IIFL_MARKETDATA_APP_KEY=
IIFL_MARKETDATA_SECRET_KEY=
IIFL_INTERACTIVE_APP_KEY=
IIFL_INTERACTIVE_SECRET_KEY=

# GFT 1K Instant - optional third isolated forex account
CB6_GFT_1K_INSTANT_ENABLED=false
CB6_GFT_1K_INSTANT_LIVE_EXECUTION=false
CB6_GFT_1K_INSTANT_STRICT_STARTUP=false
GFT_1K_MT5_LOGIN=
GFT_1K_MT5_PASSWORD=
GFT_1K_MT5_SERVER=GoatFunded-Server
GFT_1K_MT5_TERMINAL_PATH=C:/CB6_MT5/MT5_GFT_1K/terminal64.exe
CB6_GFT_1K_INSTANT_ACCOUNT_SIZE=1000
CB6_GFT_1K_INSTANT_DAILY_DD_LIMIT=30
CB6_GFT_1K_INSTANT_MAX_DD_LIMIT=60
CB6_GFT_1K_INSTANT_MAX_RISK_USD=2.50
CB6_GFT_1K_INSTANT_RISK_PER_TRADE_PCT=0.25
CB6_GFT_1K_INSTANT_MAX_LOT=0.01
CB6_GFT_1K_INSTANT_MAGIC=100061
CB6_GFT_1K_INSTANT_STATE_DIR=data/gft_1k_instant
GFT_1K_TELEGRAM_ENABLED=false
GFT_1K_TELEGRAM_BOT_TOKEN=
GFT_1K_TELEGRAM_CHAT_ID=
GFT_1K_TELEGRAM_ADMIN_IDS=
GFT_1K_TELEGRAM_COMMANDS_ENABLED=true
