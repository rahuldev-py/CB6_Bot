{
    // ── Claude Code ───────────────────────────────────────────────────────────
    "claudeCode.allowDangerouslySkipPermissions": true,
    "claudeCode.hideOnboarding": false,

    // ── Chat Customizations (Microsoft extension) ─────────────────────────────
    "github.copilot.chat.codeGeneration.useInstructionFiles": true,
    "github.copilot.chat.reviewSelection.instructions": [
        { "text": "Focus on GFT $5K and GFT $1K Instant accounts. FTMO is deprioritized." },
        { "text": "XAUUSD must never be enabled on any GFT account." },
        { "text": "Never suggest paper_mode=True in live configs." },
        { "text": "Always use encoding='utf-8' when opening Python files." }
    ],
    "github.copilot.chat.testGeneration.instructions": [
        { "text": "Test GFT risk guards: daily DD, max DD, lot sizing, XAUUSD block." },
        { "text": "State file tests must read before write, never corrupt JSON." }
    ],

    // ── Python / Pylance ──────────────────────────────────────────────────────
    "python.defaultInterpreterPath": "C:\\Users\\Rahul\\AppData\\Local\\Programs\\Python\\Python313\\python.exe",
    "python.envFile": "${workspaceFolder}/.env",
    "python.terminal.activateEnvironment": true,
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.autoSearchPaths": true,
    "python.analysis.extraPaths": [
        "${workspaceFolder}",
        "${workspaceFolder}/scanner",
        "${workspaceFolder}/utils",
        "${workspaceFolder}/data",
        "${workspaceFolder}/core",
        "${workspaceFolder}/forex_engine"
    ],
    "python.analysis.diagnosticSeverityOverrides": {
        "reportMissingImports": "warning",
        "reportMissingModuleSource": "none"
    },
    "python.testing.pytestArgs": ["tests"],
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,

    // ── Error Lens ────────────────────────────────────────────────────────────
    "errorLens.enabled": true,
    "errorLens.enabledDiagnosticLevels": ["error", "warning"],
    "errorLens.messageMaxChars": 120,
    "errorLens.delay": 500,
    "errorLens.errorBackground": "#ff000020",
    "errorLens.warningBackground": "#ff990020",
    "errorLens.fontStyleItalic": true,
    "errorLens.scrollbarHackEnabled": true,

    // ── indent-rainbow ────────────────────────────────────────────────────────
    "indentRainbow.colors": [
        "rgba(255,100,100,0.12)",
        "rgba(255,180,50,0.12)",
        "rgba(100,220,100,0.12)",
        "rgba(50,180,255,0.12)",
        "rgba(180,100,255,0.12)",
        "rgba(255,100,180,0.12)"
    ],
    "indentRainbow.errorColor": "rgba(255,0,0,0.5)",
    "indentRainbow.tabmixColor": "rgba(255,0,0,0.5)",

    // ── GitLens ───────────────────────────────────────────────────────────────
    "gitlens.currentLine.enabled": true,
    "gitlens.currentLine.format": "${authorAgo} · ${message|50}",
    "gitlens.hovers.currentLine.over": "line",
    "gitlens.codeLens.enabled": false,
    "gitlens.statusBar.enabled": true,
    "gitlens.blame.highlight.enabled": true,
    "gitlens.blame.highlight.locations": ["line"],

    // ── REST Client ───────────────────────────────────────────────────────────
    "rest-client.environmentVariables": {
        "$shared": {
            "baseUrl": "https://api.iiflcapital.com/v1",
            "fyersBaseUrl": "https://api.fyers.in/api/v3"
        }
    },
    "rest-client.timeoutinmilliseconds": 10000,
    "rest-client.showResponseInDifferentTab": true,
    "rest-client.previewOption": "full",

    // ── Editor ────────────────────────────────────────────────────────────────
    "editor.fontSize": 14,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.rulers": [100],
    "editor.minimap.enabled": true,
    "editor.minimap.maxColumn": 80,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.renderWhitespace": "trailing",
    "editor.wordWrap": "off",
    "editor.suggestSelection": "first",
    "editor.formatOnSave": false,

    // ── Terminal ──────────────────────────────────────────────────────────────
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.scrollback": 5000,
    "terminal.integrated.cwd": "${workspaceFolder}",

    // ── Files ─────────────────────────────────────────────────────────────────
    "files.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/*.pyc": true
    },
    "files.associations": {
        "*.http": "http",
        "state.json": "json",
        ".env": "properties"
    },
    "files.encoding": "utf8",

    // ── JSON ──────────────────────────────────────────────────────────────────
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features",
        "editor.formatOnSave": true,
        "editor.tabSize": 2
    },

    // ── Search ────────────────────────────────────────────────────────────────
    "search.exclude": {
        "**/__pycache__": true,
        "**/logs": true,
        "**/*.pyc": true,
        "**/data/*.json": false
    }
}
